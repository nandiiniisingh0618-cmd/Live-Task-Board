# Root .gitignore for Live Task Board monorepo

# =====================
# Backend (Spring Boot)
# =====================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties
backend/*.class
backend/.project
backend/.classpath
backend/.settings/
backend/.idea/
backend/*.iml

# =====================
# Frontend (Angular)
# =====================
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.vscode/
frontend/coverage/

# =====================
# Docker
# =====================
*.env
.env.local

# =====================
# OS / Editor
# =====================
.DS_Store
Thumbs.db
*.suo
*.user

# =====================
# Seed scripts
# =====================
seed.ps1
